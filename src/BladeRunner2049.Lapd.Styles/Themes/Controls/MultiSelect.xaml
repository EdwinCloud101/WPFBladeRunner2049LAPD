<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Controls/ComboBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Lapd.Chip" TargetType="ContentControl">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock lapd:Tracking.Spaces="2"
                               lapd:Tracking.Text="{Binding}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Padding="7,3"
                            Background="#243CB4A5"
                            BorderBrush="{StaticResource Lapd.Line}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF5FE8D2" BlurRadius="6" ShadowDepth="0" Opacity="0.2" />
                        </Border.Effect>
                        <ContentPresenter VerticalAlignment="Center">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#B38CF5E1" BlurRadius="5" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.MultiSelectItem" TargetType="ListBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Row"
                            Height="34"
                            Padding="14,0"
                            Background="Transparent"
                            BorderBrush="{StaticResource Lapd.LineFaint}"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False" VerticalAlignment="Center">
                            <ContentPresenter x:Name="Content" DockPanel.Dock="Left" VerticalAlignment="Center" />
                            <TextBlock x:Name="Mark"
                                       DockPanel.Dock="Right"
                                       Text="&#x2715;"
                                       FontSize="10"
                                       Foreground="{StaticResource Lapd.Teal}"
                                       VerticalAlignment="Center"
                                       Opacity="0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#8C5FE8D2" BlurRadius="6" ShadowDepth="0" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1A50D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1250D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
                            <Setter TargetName="Mark" Property="Opacity" Value="1" />
                            <Setter TargetName="Content" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.MultiSelectList" TargetType="ListBox">
        <Setter Property="SelectionMode" Value="Multiple" />
        <Setter Property="Background" Value="{StaticResource Lapd.PopupFill}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Lapd.MultiSelectItem}" />
        <Setter Property="ItemTemplate" Value="{StaticResource Lapd.ComboBox.ItemTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource Lapd.Line}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF5FE8D2" BlurRadius="18" ShadowDepth="0" Opacity="0.18" />
                        </Border.Effect>
                        <ScrollViewer>
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
