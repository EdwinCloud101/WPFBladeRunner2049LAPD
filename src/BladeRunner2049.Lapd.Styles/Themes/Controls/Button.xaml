<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Lapd.Button.ContentTemplate">
        <TextBlock lapd:Tracking.Spaces="2"
                   lapd:Tracking.Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="Lapd.Button" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="Padding" Value="22,10" />
        <Setter Property="Margin" Value="5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ContentTemplate" Value="{StaticResource Lapd.Button.ContentTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="OuterFrame"
                                Margin="-5"
                                BorderBrush="#3878EBD7"
                                BorderThickness="1" />
                        <Border x:Name="Chrome"
                                Background="#243CB4A5"
                                BorderBrush="#BF96F5E2"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF5FE8D2" BlurRadius="9" ShadowDepth="0" Opacity="0.4" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="InnerGlow"
                                Margin="1"
                                BorderBrush="#385FE8D2"
                                BorderThickness="3">
                            <Border.Effect>
                                <BlurEffect Radius="5" />
                            </Border.Effect>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#E68CF5E1" BlurRadius="6" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                        <Border x:Name="FocusRing"
                                Margin="-4"
                                BorderBrush="{StaticResource Lapd.TealDim}"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#3846C8B6" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="16" ShadowDepth="0" Opacity="0.55" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InnerGlow" Property="BorderBrush" Value="#4D5FE8D2" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#4D5AE6D0" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="22" ShadowDepth="0" Opacity="0.7" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InnerGlow" Property="BorderBrush" Value="#665FE8D2" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.Button.Ghost" TargetType="Button" BasedOn="{StaticResource Lapd.Button}">
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF5FE8D2" BlurRadius="6" ShadowDepth="0" Opacity="0.08" />
                            </Border.Effect>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#595AD2C8" BlurRadius="5" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                        <Border x:Name="FocusRing"
                                Margin="-4"
                                BorderBrush="{StaticResource Lapd.TealDim}"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="10" ShadowDepth="0" Opacity="0.25" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.IconButton" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Chrome"
                                Background="#1A28786E"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF5FE8D2" BlurRadius="8" ShadowDepth="0" Opacity="0.1" />
                            </Border.Effect>
                        </Border>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#735FE8D2" BlurRadius="4" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                        <Border x:Name="FocusRing"
                                Margin="-4"
                                BorderBrush="{StaticResource Lapd.TealDim}"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                            <Setter TargetName="Chrome" Property="Background" Value="#293CB4A5" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="10" ShadowDepth="0" Opacity="0.3" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#425AE6D0" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
