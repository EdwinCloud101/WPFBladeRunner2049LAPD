<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Lapd.TabItem.HeaderTemplate">
        <TextBlock lapd:Tracking.Spaces="2"
                   lapd:Tracking.Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="Lapd.TabItem" TargetType="TabItem">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="0,0,26,0" />
        <Setter Property="HeaderTemplate" Value="{StaticResource Lapd.TabItem.HeaderTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Grid>
                        <Border x:Name="OuterFrame"
                                Margin="-4"
                                BorderBrush="#3878EBD7"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="0,3">
                            <ContentPresenter x:Name="Hd"
                                              ContentSource="Header"
                                              VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#4050C8B4" BlurRadius="4" ShadowDepth="0" />
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                            <Setter TargetName="Chrome" Property="Background" Value="#243CB4A5" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#BF96F5E2" />
                            <Setter TargetName="Chrome" Property="Padding" Value="7,3" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="9" ShadowDepth="0" Opacity="0.4" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Hd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#E68CF5E1" BlurRadius="5" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="OuterFrame" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.TabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0"
                                  IsItemsHost="True"
                                  Margin="4,0,4,10" />
                        <Grid Grid.Row="1" MinHeight="96">
                            <Border Background="{StaticResource Lapd.FillWell}"
                                    BorderBrush="{StaticResource Lapd.LineDim}"
                                    BorderThickness="1" />
                            <Border Margin="1"
                                    BorderBrush="#1446C8B4"
                                    BorderThickness="7">
                                <Border.Effect>
                                    <BlurEffect Radius="10" />
                                </Border.Effect>
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent"
                                              Margin="16,14" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.PaneText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#595AD2C8" BlurRadius="5" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.PaneTextDim" TargetType="TextBlock" BasedOn="{StaticResource Lapd.PaneText}">
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

</ResourceDictionary>
