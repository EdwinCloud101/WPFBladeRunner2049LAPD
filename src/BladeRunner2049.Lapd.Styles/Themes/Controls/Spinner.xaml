<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Lapd.Spinner" TargetType="ContentControl">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Rectangle Stroke="{StaticResource Lapd.LineFaint}" StrokeThickness="1" />
                        <Path x:Name="Arc"
                              Data="M0.5,0.5 L25.5,0.5 L25.5,25.5"
                              Stroke="{StaticResource Lapd.Teal}"
                              StrokeThickness="1"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Path.RenderTransform>
                            <Path.Effect>
                                <DropShadowEffect Color="#8C5FE8D2" BlurRadius="4" ShadowDepth="0" />
                            </Path.Effect>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Path.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                           Duration="0:0:1.4"
                                                                           RepeatBehavior="Forever">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.175" Value="45" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.35" Value="90" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.525" Value="135" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.7" Value="180" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.875" Value="225" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.05" Value="270" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.225" Value="315" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SpinnerSmooth" TargetType="ContentControl">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <Rectangle Stroke="{StaticResource Lapd.LineFaint}" StrokeThickness="1" />
                        <Path x:Name="Arc"
                              Data="M0.5,0.5 L19.5,0.5 L19.5,19.5"
                              Stroke="{StaticResource Lapd.Teal}"
                              StrokeThickness="1"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Path.RenderTransform>
                            <Path.Effect>
                                <DropShadowEffect Color="#8C5FE8D2" BlurRadius="4" ShadowDepth="0" />
                            </Path.Effect>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Path.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360"
                                                             Duration="0:0:1.1"
                                                             RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SpinnerLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
