<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Controls/TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="Lapd.PopupFill" Color="#F7091B1E" />

    <DataTemplate x:Key="Lapd.ComboBox.ItemTemplate">
        <TextBlock lapd:Tracking.Spaces="2"
                   lapd:Tracking.Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="Lapd.ComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Row"
                            Height="34"
                            Padding="14,0"
                            Background="Transparent"
                            BorderBrush="{StaticResource Lapd.LineFaint}"
                            BorderThickness="0,0,0,1">
                        <ContentPresenter x:Name="Content" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1A50D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                            <Setter TargetName="Content" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#998CF5E1" BlurRadius="6" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1250D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
                            <Setter TargetName="Content" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.ComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="300" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ItemTemplate" Value="{StaticResource Lapd.ComboBox.ItemTemplate}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Lapd.ComboBoxItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Shell"
                                      Focusable="False"
                                      ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Grid>
                                        <Border Background="{StaticResource Lapd.FillWell}" />
                                        <Border x:Name="Chrome"
                                                Background="{StaticResource Lapd.TextBox.Fill}"
                                                BorderBrush="{StaticResource Lapd.LineDim}"
                                                BorderThickness="1" />
                                        <Border Margin="1"
                                                BorderBrush="#1746C8B4"
                                                BorderThickness="5">
                                            <Border.Effect>
                                                <BlurEffect Radius="8" />
                                            </Border.Effect>
                                        </Border>
                                        <Path x:Name="Arrow"
                                              Data="M0,0 L10,0 L5,6 Z"
                                              Fill="{StaticResource Lapd.TealMid}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,14,0"
                                              RenderTransformOrigin="0.5,0.5">
                                            <Path.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Path.RenderTransform>
                                            <Path.Effect>
                                                <DropShadowEffect Color="#805AD2C8" BlurRadius="3" ShadowDepth="0" />
                                            </Path.Effect>
                                        </Path>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                                            <Setter TargetName="Chrome" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="12" ShadowDepth="0" Opacity="0.2" />
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="180" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="14,0,34,0"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               VerticalOffset="4"
                               AllowsTransparency="True"
                               PopupAnimation="None">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource Lapd.PopupFill}"
                                    BorderBrush="{StaticResource Lapd.Line}"
                                    BorderThickness="1"
                                    Margin="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="18" ShadowDepth="0" Opacity="0.18" />
                                </Border.Effect>
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
