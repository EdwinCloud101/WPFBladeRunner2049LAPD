<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Lapd.Slider.TrackFill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#735FDCC8" Offset="0" />
        <GradientStop Color="#2E5FDCC8" Offset="1" />
    </LinearGradientBrush>

    <ControlTemplate x:Key="Lapd.Slider.Repeat" TargetType="RepeatButton">
        <Border Background="Transparent" />
    </ControlTemplate>

    <Style x:Key="Lapd.Slider.Thumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Width="4" Height="18" Fill="{StaticResource Lapd.TealBright}">
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#E696F8E6" BlurRadius="10" ShadowDepth="0" />
                        </Rectangle.Effect>
                    </Rectangle>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.Slider" TargetType="Slider">
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Rectangle Height="2"
                                   VerticalAlignment="Center"
                                   Fill="{StaticResource Lapd.Slider.TrackFill}">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FF5ADCC8" BlurRadius="5" ShadowDepth="0" Opacity="0.25" />
                            </Rectangle.Effect>
                        </Rectangle>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Template="{StaticResource Lapd.Slider.Repeat}"
                                              Command="{x:Static Slider.DecreaseLarge}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Template="{StaticResource Lapd.Slider.Repeat}"
                                              Command="{x:Static Slider.IncreaseLarge}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Lapd.Slider.Thumb}" />
                            </Track.Thumb>
                        </Track>
                        <Rectangle x:Name="FocusRing"
                                   Margin="-4"
                                   Stroke="{StaticResource Lapd.TealDim}"
                                   StrokeThickness="1"
                                   StrokeDashArray="2 2"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SliderName" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SliderValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontDisplay}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#735FE8D2" BlurRadius="6" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
