<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Lapd.Progress.Fill" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7378F0DC" Offset="0" />
        <GradientStop Color="#FFAEFCEC" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Lapd.Progress" TargetType="ProgressBar">
        <Setter Property="Height" Value="5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" Background="#1A5FDCC8" />
                        <Border Background="#73000000" Margin="0">
                            <Border.OpacityMask>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF000000" Offset="0" />
                                    <GradientStop Color="#00000000" Offset="0.6" />
                                </LinearGradientBrush>
                            </Border.OpacityMask>
                        </Border>
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{StaticResource Lapd.Progress.Fill}">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF96F8E6" BlurRadius="12" ShadowDepth="0" Opacity="0.7" />
                            </Border.Effect>
                        </Border>
                        <Rectangle x:Name="ScanRect" Visibility="Collapsed">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="#FF96F8E6" BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                            </Rectangle.Effect>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TranslateTransform X="0" />
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#7378F0DC" Offset="0.001" />
                                    <GradientStop Color="#FFAEFCEC" Offset="0.259" />
                                    <GradientStop Color="#00000000" Offset="0.26" />
                                    <GradientStop Color="#00000000" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ScanRect" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ScanRect"
                                                         Storyboard.TargetProperty="(Shape.Fill).(Brush.RelativeTransform).(TranslateTransform.X)"
                                                         From="0" To="0.74"
                                                         Duration="0:0:2"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
