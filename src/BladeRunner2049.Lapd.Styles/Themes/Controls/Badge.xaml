<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Lapd.Badge.ContentTemplate">
        <TextBlock lapd:Tracking.Spaces="2"
                   lapd:Tracking.Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="Lapd.Badge" TargetType="ContentControl">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="ContentTemplate" Value="{StaticResource Lapd.Badge.ContentTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Chrome"
                            Padding="9,4"
                            Background="#1A28786E"
                            BorderBrush="{StaticResource Lapd.LineDim}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="5" Height="5"
                                       VerticalAlignment="Center"
                                       Fill="{TemplateBinding Foreground}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="5" ShadowDepth="0" Opacity="0.8" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.Badge.On" TargetType="ContentControl" BasedOn="{StaticResource Lapd.Badge}">
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Chrome"
                            Padding="9,4"
                            Background="#243CB4A5"
                            BorderBrush="#BF96F5E2"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF5FE8D2" BlurRadius="9" ShadowDepth="0" Opacity="0.35" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="5" Height="5"
                                       VerticalAlignment="Center"
                                       Fill="{TemplateBinding Foreground}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FF96F8E6" BlurRadius="5" ShadowDepth="0" Opacity="0.9" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#E68CF5E1" BlurRadius="5" ShadowDepth="0" />
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.Badge.Alert" TargetType="ContentControl" BasedOn="{StaticResource Lapd.Badge}">
        <Setter Property="Foreground" Value="#FFFF9A72" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border x:Name="Chrome"
                            Padding="9,4"
                            Background="#24782814"
                            BorderBrush="#8CFF6E3C"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF5A28" BlurRadius="9" ShadowDepth="0" Opacity="0.25" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="5" Height="5"
                                       VerticalAlignment="Center"
                                       Fill="{TemplateBinding Foreground}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FFFF9A72" BlurRadius="5" ShadowDepth="0" Opacity="0.9" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#8CFF6432" BlurRadius="6" ShadowDepth="0" />
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
