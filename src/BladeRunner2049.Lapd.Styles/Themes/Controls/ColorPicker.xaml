<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Lapd.Swatch" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Rectangle x:Name="Sw"
                                   Width="22" Height="22"
                                   Fill="{TemplateBinding Background}"
                                   Stroke="#24FFFFFF"
                                   StrokeThickness="1"
                                   Opacity="0.9">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="{Binding Fill.Color, ElementName=Sw}" BlurRadius="7" ShadowDepth="0" Opacity="0.8" />
                            </Rectangle.Effect>
                        </Rectangle>
                        <Rectangle x:Name="SelRing"
                                   Margin="-4"
                                   Stroke="{StaticResource Lapd.TealBright}"
                                   StrokeThickness="1"
                                   Visibility="Collapsed" />
                        <Rectangle x:Name="FocusRing"
                                   Margin="-6"
                                   Stroke="{StaticResource Lapd.TealDim}"
                                   StrokeThickness="1"
                                   StrokeDashArray="2 2"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Sw" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SelRing" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Sw" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.ColorWell" TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border Background="{StaticResource Lapd.FillWell}" />
                        <Border x:Name="Chrome"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1"
                                Padding="2">
                            <Rectangle Fill="{TemplateBinding Background}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="10" ShadowDepth="0" Opacity="0.25" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
