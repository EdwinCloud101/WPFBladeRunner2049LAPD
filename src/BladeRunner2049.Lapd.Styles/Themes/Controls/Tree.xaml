<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate x:Key="Lapd.TreeItem.HeaderTemplate">
        <TextBlock lapd:Tracking.Spaces="2"
                   lapd:Tracking.Text="{Binding}" />
    </DataTemplate>

    <Style x:Key="Lapd.TreeItem" TargetType="TreeViewItem">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HeaderTemplate" Value="{StaticResource Lapd.TreeItem.HeaderTemplate}" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource Lapd.TreeItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Grid>
                            <Border x:Name="Hd"
                                    Height="27"
                                    Padding="7,0"
                                    Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="Car"
                                          Data="M0,0 L5,4 L0,8 Z"
                                          Fill="{StaticResource Lapd.TealDim}"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                        <Path.Effect>
                                            <DropShadowEffect Color="#665AD2C8" BlurRadius="3" ShadowDepth="0" />
                                        </Path.Effect>
                                    </Path>
                                    <ContentPresenter x:Name="HdContent"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center">
                                        <ContentPresenter.Effect>
                                            <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
                                        </ContentPresenter.Effect>
                                    </ContentPresenter>
                                </StackPanel>
                            </Border>
                            <Rectangle x:Name="SelBar"
                                       Width="2"
                                       HorizontalAlignment="Left"
                                       Fill="{StaticResource Lapd.Teal}"
                                       Visibility="Collapsed">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="{StaticResource Lapd.GlowColor}" BlurRadius="6" ShadowDepth="0" />
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                        <Border x:Name="Children"
                                Margin="10,0,0,0"
                                Padding="15,0,0,0"
                                BorderBrush="{StaticResource Lapd.LineFaint}"
                                BorderThickness="1,0,0,0"
                                Visibility="Collapsed">
                            <ItemsPresenter />
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="Children" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Car" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Car" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Hd" Property="Padding" Value="18,0,7,0" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
                        </Trigger>
                        <Trigger SourceName="Hd" Property="IsMouseOver" Value="True">
                            <Setter TargetName="Hd" Property="Background" Value="#1250D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Hd" Property="Background" Value="#1A50D2BE" />
                            <Setter TargetName="SelBar" Property="Visibility" Value="Visible" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
                            <Setter TargetName="HdContent" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.Tree" TargetType="TreeView">
        <Setter Property="ItemContainerStyle" Value="{StaticResource Lapd.TreeItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeView">
                    <Grid>
                        <Border Background="{StaticResource Lapd.FillWell}"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1" />
                        <Border Margin="1"
                                BorderBrush="#1246C8B4"
                                BorderThickness="7">
                            <Border.Effect>
                                <BlurEffect Radius="10" />
                            </Border.Effect>
                        </Border>
                        <ItemsPresenter Margin="12,10" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
