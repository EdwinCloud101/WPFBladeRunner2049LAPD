<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Lapd.GridHeaderFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38205F5A" Offset="0" />
        <GradientStop Color="#290E2C2D" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Lapd.GridHeader" TargetType="GridViewColumnHeader">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Height="30"
                            Background="{StaticResource Lapd.GridHeaderFill}"
                            BorderBrush="{StaticResource Lapd.LineDim}"
                            BorderThickness="0,0,0,1">
                        <ContentPresenter Margin="14,0,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                            <ContentPresenter.Effect>
                                <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.GridRow" TargetType="ListViewItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Grid>
                        <Border x:Name="Row"
                                Height="36"
                                Background="Transparent"
                                BorderBrush="{StaticResource Lapd.LineFaint}"
                                BorderThickness="0,0,0,1">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}"
                                                  VerticalAlignment="Center" />
                        </Border>
                        <Rectangle x:Name="SelBar"
                                   Width="2"
                                   HorizontalAlignment="Left"
                                   Fill="{StaticResource Lapd.Teal}"
                                   Visibility="Collapsed">
                            <Rectangle.Effect>
                                <DropShadowEffect Color="{StaticResource Lapd.GlowColor}" BlurRadius="6" ShadowDepth="0" />
                            </Rectangle.Effect>
                        </Rectangle>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#0F50D2BE" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1A50D2BE" />
                            <Setter TargetName="SelBar" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.DataGrid" TargetType="ListView">
        <Setter Property="Background" Value="{StaticResource Lapd.FillWell}" />
        <Setter Property="BorderBrush" Value="{StaticResource Lapd.LineDim}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Lapd.GridRow}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="Lapd.GridText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Margin" Value="14,0,0,0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4D5AD2C8" BlurRadius="5" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.GridId" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontDisplay}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="Margin" Value="14,0,0,0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#735FE8D2" BlurRadius="6" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.GridX" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Margin" Value="14,0,0,0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#8C5FE8D2" BlurRadius="6" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
