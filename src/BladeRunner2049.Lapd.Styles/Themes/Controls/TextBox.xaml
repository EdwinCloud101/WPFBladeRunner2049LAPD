<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Lapd.TextBox.Fill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2E205F5A" Offset="0" />
        <GradientStop Color="#240E2C2D" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Lapd.TextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="CaretBrush" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="SelectionBrush" Value="#4D5FE8D2" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border Background="{StaticResource Lapd.FillWell}" />
                        <Border x:Name="Chrome"
                                Background="{StaticResource Lapd.TextBox.Fill}"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1" />
                        <Border x:Name="InsetGlow"
                                Margin="1"
                                BorderBrush="#1746C8B4"
                                BorderThickness="5">
                            <Border.Effect>
                                <BlurEffect Radius="8" />
                            </Border.Effect>
                        </Border>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center">
                            <ScrollViewer.Effect>
                                <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                            </ScrollViewer.Effect>
                        </ScrollViewer>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="14" ShadowDepth="0" Opacity="0.22" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InsetGlow" Property="BorderBrush" Value="#2946C8B4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <RadialGradientBrush x:Key="Lapd.TextArea.Fill" Center="0.5,0.4" GradientOrigin="0.5,0.4" RadiusX="0.9" RadiusY="0.7">
        <GradientStop Color="#1655D7C0" Offset="0" />
        <GradientStop Color="#08286E64" Offset="0.7" />
    </RadialGradientBrush>

    <Style x:Key="Lapd.TextArea" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="CaretBrush" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="SelectionBrush" Value="#4D5FE8D2" />
        <Setter Property="Height" Value="150" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border Background="{StaticResource Lapd.FillWell}" />
                        <Border x:Name="Chrome"
                                Background="{StaticResource Lapd.TextArea.Fill}"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1" />
                        <Border x:Name="InsetGlow"
                                Margin="1"
                                BorderBrush="#1A46C8B4"
                                BorderThickness="8">
                            <Border.Effect>
                                <BlurEffect Radius="12" />
                            </Border.Effect>
                        </Border>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}">
                            <ScrollViewer.Effect>
                                <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                            </ScrollViewer.Effect>
                        </ScrollViewer>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="14" ShadowDepth="0" Opacity="0.22" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="InsetGlow" Property="BorderBrush" Value="#2946C8B4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
