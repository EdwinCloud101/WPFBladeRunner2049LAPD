<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Core.xaml" />
        <ResourceDictionary Source="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Themes/Controls/ComboBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <LinearGradientBrush x:Key="Lapd.AutoComplete.HeadFill" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#38205F5A" Offset="0" />
        <GradientStop Color="#290E2C2D" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Lapd.AutoCompleteTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CaretBrush" Value="{StaticResource Lapd.TealBright}" />
        <Setter Property="SelectionBrush" Value="#4D5FE8D2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center">
                        <ScrollViewer.Effect>
                            <DropShadowEffect Color="#805FE8D2" BlurRadius="6" ShadowDepth="0" />
                        </ScrollViewer.Effect>
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.AutoCompleteItem" TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Row"
                            Height="32"
                            Padding="14,0"
                            Background="Transparent"
                            BorderBrush="{StaticResource Lapd.LineFaint}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M0,0 L4,3 L0,6 Z"
                                  Fill="{StaticResource Lapd.TealDim}"
                                  Margin="0,0,9,0"
                                  VerticalAlignment="Center" />
                            <ContentPresenter x:Name="Content" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Row" Property="Background" Value="#1A50D2BE" />
                            <Setter Property="Foreground" Value="{StaticResource Lapd.TealBright}" />
                            <Setter TargetName="Content" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#998CF5E1" BlurRadius="6" ShadowDepth="0" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.AutoComplete" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.Teal}" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Width" Value="420" />
        <Setter Property="IsEditable" Value="True" />
        <Setter Property="StaysOpenOnEdit" Value="True" />
        <Setter Property="ItemTemplate" Value="{StaticResource Lapd.ComboBox.ItemTemplate}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Lapd.AutoCompleteItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border Background="{StaticResource Lapd.FillWell}" />
                        <Border x:Name="Chrome"
                                Background="{StaticResource Lapd.TextBox.Fill}"
                                BorderBrush="{StaticResource Lapd.LineDim}"
                                BorderThickness="1" />
                        <Border Margin="1"
                                BorderBrush="#1746C8B4"
                                BorderThickness="5">
                            <Border.Effect>
                                <BlurEffect Radius="8" />
                            </Border.Effect>
                        </Border>
                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{StaticResource Lapd.AutoCompleteTextBox}"
                                 Margin="12,6"
                                 FontFamily="{TemplateBinding FontFamily}"
                                 FontSize="{TemplateBinding FontSize}"
                                 Foreground="{TemplateBinding Foreground}" />
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               VerticalOffset="4"
                               AllowsTransparency="True"
                               PopupAnimation="None">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource Lapd.PopupFill}"
                                    BorderBrush="{StaticResource Lapd.Line}"
                                    BorderThickness="1"
                                    Margin="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="18" ShadowDepth="0" Opacity="0.18" />
                                </Border.Effect>
                                <StackPanel>
                                    <Border Height="24"
                                            Padding="14,0"
                                            Background="{StaticResource Lapd.AutoComplete.HeadFill}"
                                            BorderBrush="{StaticResource Lapd.LineDim}"
                                            BorderThickness="0,0,0,1">
                                        <TextBlock FontFamily="{StaticResource Lapd.FontMono}"
                                                   FontSize="7"
                                                   Foreground="{StaticResource Lapd.TealDim}"
                                                   VerticalAlignment="Center"
                                                   lapd:Tracking.Spaces="2"
                                                   lapd:Tracking.Text="SUGGESTED ENTRIES" />
                                    </Border>
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Lapd.Line}" />
                            <Setter TargetName="Chrome" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF5FE8D2" BlurRadius="12" ShadowDepth="0" Opacity="0.2" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="IsDropDownOpen" Value="True" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
