<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Lapd.FontMono">pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Fonts/#Share Tech Mono</FontFamily>
    <FontFamily x:Key="Lapd.FontDisplay">pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Fonts/#Orbitron</FontFamily>

    <Color x:Key="Lapd.TealColor">#FF5FE8D2</Color>
    <Color x:Key="Lapd.TealBrightColor">#FFAEFCEC</Color>
    <Color x:Key="Lapd.TealMidColor">#BF6EE6D2</Color>
    <Color x:Key="Lapd.TealDimColor">#6B50BEAF</Color>
    <Color x:Key="Lapd.LineColor">#807DEBD7</Color>
    <Color x:Key="Lapd.LineDimColor">#426EDCC8</Color>
    <Color x:Key="Lapd.LineFaintColor">#2464D2C3</Color>
    <Color x:Key="Lapd.RedAbColor">#73FF3E1E</Color>
    <Color x:Key="Lapd.BlueAbColor">#4728AAFF</Color>
    <Color x:Key="Lapd.GlowColor">#8C5FE8D2</Color>
    <Color x:Key="Lapd.BgDeepColor">#FF03070B</Color>
    <Color x:Key="Lapd.FillWellColor">#2E102A2D</Color>

    <SolidColorBrush x:Key="Lapd.Teal" Color="{StaticResource Lapd.TealColor}" />
    <SolidColorBrush x:Key="Lapd.TealBright" Color="{StaticResource Lapd.TealBrightColor}" />
    <SolidColorBrush x:Key="Lapd.TealMid" Color="{StaticResource Lapd.TealMidColor}" />
    <SolidColorBrush x:Key="Lapd.TealDim" Color="{StaticResource Lapd.TealDimColor}" />
    <SolidColorBrush x:Key="Lapd.Line" Color="{StaticResource Lapd.LineColor}" />
    <SolidColorBrush x:Key="Lapd.LineDim" Color="{StaticResource Lapd.LineDimColor}" />
    <SolidColorBrush x:Key="Lapd.LineFaint" Color="{StaticResource Lapd.LineFaintColor}" />
    <SolidColorBrush x:Key="Lapd.RedAb" Color="{StaticResource Lapd.RedAbColor}" />
    <SolidColorBrush x:Key="Lapd.BlueAb" Color="{StaticResource Lapd.BlueAbColor}" />
    <SolidColorBrush x:Key="Lapd.Glow" Color="{StaticResource Lapd.GlowColor}" />
    <SolidColorBrush x:Key="Lapd.BgDeep" Color="{StaticResource Lapd.BgDeepColor}" />
    <SolidColorBrush x:Key="Lapd.FillWell" Color="{StaticResource Lapd.FillWellColor}" />

    <LinearGradientBrush x:Key="Lapd.BgHorizontal" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF060E13" Offset="0" />
        <GradientStop Color="#FF0E1F26" Offset="0.18" />
        <GradientStop Color="#FF102229" Offset="0.5" />
        <GradientStop Color="#FF0E1F26" Offset="0.82" />
        <GradientStop Color="#FF050B0F" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="Lapd.BgTopGlow" Center="0.5,0" GradientOrigin="0.5,0" RadiusX="1.2" RadiusY="0.6">
        <GradientStop Color="#80265862" Offset="0" />
        <GradientStop Color="#66143038" Offset="0.38" />
        <GradientStop Color="#00050C10" Offset="0.78" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="Lapd.BgCornerShadow" Center="0.03,0.01" GradientOrigin="0.03,0.01" RadiusX="0.22" RadiusY="0.16">
        <GradientStop Color="#A6000203" Offset="0" />
        <GradientStop Color="#00000203" Offset="0.7" />
    </RadialGradientBrush>

    <DrawingBrush x:Key="Lapd.Scanlines" TileMode="Tile" Viewport="0,0,3,3" ViewportUnits="Absolute" Stretch="None">
        <DrawingBrush.Drawing>
            <GeometryDrawing Brush="#21000406">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,3,1" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <RadialGradientBrush x:Key="Lapd.VignetteRadial" Center="0.5,0.44" GradientOrigin="0.5,0.44" RadiusX="1.05" RadiusY="0.9">
        <GradientStop Color="#00010406" Offset="0.4" />
        <GradientStop Color="#73010406" Offset="0.8" />
        <GradientStop Color="#CC000203" Offset="1" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="Lapd.VignetteSides" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#99000305" Offset="0" />
        <GradientStop Color="#00000305" Offset="0.08" />
        <GradientStop Color="#00000305" Offset="0.92" />
        <GradientStop Color="#99000305" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeWashLeft" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4255E6C0" Offset="0" />
        <GradientStop Color="#1741C8AA" Offset="0.45" />
        <GradientStop Color="#0041C8AA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeWashRight" StartPoint="1,0" EndPoint="0,0">
        <GradientStop Color="#4D55E6C0" Offset="0" />
        <GradientStop Color="#1A41C8AA" Offset="0.45" />
        <GradientStop Color="#0041C8AA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeBandLeft" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6BC3FFEC" Offset="0" />
        <GradientStop Color="#3396FCDC" Offset="0.36" />
        <GradientStop Color="#0096FCDC" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeBandRight" StartPoint="1,0" EndPoint="0,0">
        <GradientStop Color="#7AC3FFEC" Offset="0" />
        <GradientStop Color="#3896FCDC" Offset="0.36" />
        <GradientStop Color="#0096FCDC" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeCoreLeft" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#8CD2FFF0" Offset="0" />
        <GradientStop Color="#F2EBFFF8" Offset="0.16" />
        <GradientStop Color="#99CDFFEE" Offset="0.38" />
        <GradientStop Color="#FFF0FFFA" Offset="0.58" />
        <GradientStop Color="#B3D7FFF0" Offset="0.78" />
        <GradientStop Color="#E6EBFFF8" Offset="0.94" />
        <GradientStop Color="#80D2FFF0" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.EdgeCoreRight" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#99D2FFF0" Offset="0" />
        <GradientStop Color="#A6CDFFEE" Offset="0.12" />
        <GradientStop Color="#FFF0FFFA" Offset="0.32" />
        <GradientStop Color="#A6D4FFF0" Offset="0.55" />
        <GradientStop Color="#F2EEFFF9" Offset="0.76" />
        <GradientStop Color="#8CCDFFEE" Offset="0.92" />
        <GradientStop Color="#99D7FFF0" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.MastheadHead" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4D205F5A" Offset="0" />
        <GradientStop Color="#420E2C2D" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.ViewTab" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#8C123434" Offset="0" />
        <GradientStop Color="#730A1E20" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Lapd.FooterBar" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4078F0DC" Offset="0" />
        <GradientStop Color="#FFAEFCEC" Offset="0.12" />
        <GradientStop Color="#FFAEFCEC" Offset="0.88" />
        <GradientStop Color="#4078F0DC" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="Lapd.MicroLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#665AD2C8" BlurRadius="5" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SectionNumber" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
    </Style>

    <Style x:Key="Lapd.SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealMid}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#595AD2C8" BlurRadius="5" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Lapd.SectionJp" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Lapd.FontMono}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="Foreground" Value="{StaticResource Lapd.TealDim}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#4D50C8B4" BlurRadius="4" ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
