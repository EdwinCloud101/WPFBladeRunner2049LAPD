<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
                    xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls">

    <Style TargetType="controls:ConsoleShell">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ConsoleShell">
                    <Grid>
                        <Rectangle Fill="{StaticResource Lapd.BgHorizontal}" />
                        <Rectangle Fill="{StaticResource Lapd.BgTopGlow}" />
                        <Rectangle Fill="{StaticResource Lapd.BgCornerShadow}" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Width="660" Margin="0,64,0,90" HorizontalAlignment="Center">
                                <StackPanel.Effect>
                                    <BlurEffect Radius="0.28" />
                                </StackPanel.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Height="52"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource Lapd.ViewTab}"
                                            BorderBrush="{StaticResource Lapd.LineDim}"
                                            BorderThickness="1,1,0,1"
                                            Padding="7,4,0,0">
                                        <StackPanel>
                                            <TextBlock FontFamily="{StaticResource Lapd.FontMono}"
                                                       FontSize="7"
                                                       Foreground="{StaticResource Lapd.TealDim}"
                                                       lapd:Tracking.Spaces="2"
                                                       lapd:Tracking.Text="VIEW" />
                                            <Grid Margin="0,1,0,0" HorizontalAlignment="Left">
                                                <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                           FontWeight="SemiBold"
                                                           FontSize="26"
                                                           Foreground="{StaticResource Lapd.RedAb}"
                                                           Text="C">
                                                    <TextBlock.RenderTransform>
                                                        <TranslateTransform X="-1.5" Y="0.5" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                           FontWeight="SemiBold"
                                                           FontSize="26"
                                                           Foreground="{StaticResource Lapd.BlueAb}"
                                                           Text="C">
                                                    <TextBlock.RenderTransform>
                                                        <TranslateTransform X="1" Y="0" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                           FontWeight="SemiBold"
                                                           FontSize="26"
                                                           Foreground="{StaticResource Lapd.Teal}"
                                                           Text="C">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="{StaticResource Lapd.GlowColor}" BlurRadius="7" ShadowDepth="0" />
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Column="1" Height="60">
                                        <Grid.Clip>
                                            <PathGeometry Figures="M13,0 L610,0 L610,60 L0,60 L0,13 Z" />
                                        </Grid.Clip>
                                        <Border Background="{StaticResource Lapd.MastheadHead}"
                                                BorderBrush="{StaticResource Lapd.Line}"
                                                BorderThickness="1" />
                                        <Border Margin="1"
                                                BorderBrush="#2450DCC6"
                                                BorderThickness="4">
                                            <Border.Effect>
                                                <BlurEffect Radius="7" />
                                            </Border.Effect>
                                        </Border>
                                        <Rectangle Height="1"
                                                   Margin="1"
                                                   VerticalAlignment="Bottom"
                                                   Fill="#5996F5E2" />
                                        <Border Margin="2"
                                                BorderBrush="#1A78EBD7"
                                                BorderThickness="1" />
                                        <Rectangle Width="19" Height="1"
                                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                                   Margin="-3,5.5,0,0"
                                                   Fill="{StaticResource Lapd.Line}"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <RotateTransform Angle="-45" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                        <StackPanel Margin="14,7,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M0,0 L4,3 L0,6 Z"
                                                      Fill="{StaticResource Lapd.TealMid}"
                                                      Margin="0,0,6,0"
                                                      VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource Lapd.MicroLabel}"
                                                           lapd:Tracking.Spaces="1"
                                                           lapd:Tracking.Text="LAPD OS 9.22 // UI KIT" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Rectangle x:Name="CaretBar"
                                                           Width="3" Height="21"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"
                                                           Fill="{StaticResource Lapd.TealBright}">
                                                    <Rectangle.Effect>
                                                        <DropShadowEffect Color="#E696F8E6" BlurRadius="10" ShadowDepth="0" />
                                                    </Rectangle.Effect>
                                                </Rectangle>
                                                <Grid>
                                                    <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                               FontWeight="SemiBold"
                                                               FontSize="22"
                                                               Foreground="{StaticResource Lapd.RedAb}"
                                                               lapd:Tracking.Spaces="1"
                                                               lapd:Tracking.Text="{Binding MastheadTitle, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform X="-1.5" Y="0.5" />
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                               FontWeight="SemiBold"
                                                               FontSize="22"
                                                               Foreground="{StaticResource Lapd.BlueAb}"
                                                               lapd:Tracking.Spaces="1"
                                                               lapd:Tracking.Text="{Binding MastheadTitle, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <TextBlock.RenderTransform>
                                                            <TranslateTransform X="1.5" Y="0" />
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="{StaticResource Lapd.FontDisplay}"
                                                               FontWeight="SemiBold"
                                                               FontSize="22"
                                                               Foreground="{StaticResource Lapd.Teal}"
                                                               lapd:Tracking.Spaces="1"
                                                               lapd:Tracking.Text="{Binding MastheadTitle, RelativeSource={RelativeSource TemplatedParent}}">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="{StaticResource Lapd.GlowColor}" BlurRadius="7" ShadowDepth="0" />
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <Border BorderBrush="{StaticResource Lapd.LineFaint}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,5"
                                        Margin="0,46,0,14">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Style="{StaticResource Lapd.SectionNumber}"
                                                   VerticalAlignment="Bottom"
                                                   lapd:Tracking.Spaces="1"
                                                   lapd:Tracking.Text="{Binding SectionNumber, RelativeSource={RelativeSource TemplatedParent}}" />
                                        <TextBlock DockPanel.Dock="Left"
                                                   Style="{StaticResource Lapd.SectionTitle}"
                                                   VerticalAlignment="Bottom"
                                                   Margin="10,0,0,0"
                                                   lapd:Tracking.Spaces="2"
                                                   lapd:Tracking.Text="{Binding SectionTitle, RelativeSource={RelativeSource TemplatedParent}}" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Style="{StaticResource Lapd.SectionJp}"
                                                   VerticalAlignment="Bottom"
                                                   Text="{Binding JpLabel, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </DockPanel>
                                </Border>

                                <ContentPresenter />

                                <Grid Margin="0,64,0,0">
                                    <Rectangle Height="5" Width="409"
                                               Fill="{StaticResource Lapd.FooterBar}">
                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#FF96F8E6" BlurRadius="22" ShadowDepth="0" Opacity="0.7" />
                                        </Rectangle.Effect>
                                    </Rectangle>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <Rectangle Fill="{StaticResource Lapd.Scanlines}" IsHitTestVisible="False" />
                        <Rectangle x:Name="GrainLayer"
                                   Margin="-80"
                                   Opacity="0.08"
                                   IsHitTestVisible="False">
                            <Rectangle.RenderTransform>
                                <TranslateTransform />
                            </Rectangle.RenderTransform>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="pack://application:,,,/BladeRunner2049.Lapd.Styles;component/Assets/grain.png"
                                            TileMode="Tile"
                                            Viewport="0,0,280,280"
                                            ViewportUnits="Absolute"
                                            Stretch="None" />
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Fill="{StaticResource Lapd.VignetteRadial}" IsHitTestVisible="False" />
                        <Rectangle Fill="{StaticResource Lapd.VignetteSides}" IsHitTestVisible="False" />

                        <Grid x:Name="EdgeGlow" IsHitTestVisible="False" Opacity="0.92">
                            <Rectangle Width="120" HorizontalAlignment="Left" Fill="{StaticResource Lapd.EdgeWashLeft}">
                                <Rectangle.Effect>
                                    <BlurEffect Radius="9" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Rectangle Width="56" HorizontalAlignment="Left" Fill="{StaticResource Lapd.EdgeBandLeft}">
                                <Rectangle.Effect>
                                    <BlurEffect Radius="2.5" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Rectangle Width="2.5" HorizontalAlignment="Left" Fill="{StaticResource Lapd.EdgeCoreLeft}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FFBEFFE8" BlurRadius="16" ShadowDepth="0" Opacity="0.9" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Rectangle Width="120" HorizontalAlignment="Right" Fill="{StaticResource Lapd.EdgeWashRight}">
                                <Rectangle.Effect>
                                    <BlurEffect Radius="9" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Rectangle Width="56" HorizontalAlignment="Right" Fill="{StaticResource Lapd.EdgeBandRight}">
                                <Rectangle.Effect>
                                    <BlurEffect Radius="2.5" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Rectangle Width="2.5" HorizontalAlignment="Right" Fill="{StaticResource Lapd.EdgeCoreRight}">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="#FFBEFFE8" BlurRadius="16" ShadowDepth="0" Opacity="0.95" />
                                </Rectangle.Effect>
                            </Rectangle>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CaretBar"
                                                                   Storyboard.TargetProperty="Opacity"
                                                                   Duration="0:0:1.3"
                                                                   RepeatBehavior="Forever">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.715" Value="0.25" />
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EdgeGlow"
                                                                   Storyboard.TargetProperty="Opacity"
                                                                   Duration="0:0:7"
                                                                   RepeatBehavior="Forever">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.92" />
                                        <LinearDoubleKeyFrame KeyTime="0:0:2.1" Value="1" />
                                        <LinearDoubleKeyFrame KeyTime="0:0:3.64" Value="0.88" />
                                        <LinearDoubleKeyFrame KeyTime="0:0:5.32" Value="0.98" />
                                        <LinearDoubleKeyFrame KeyTime="0:0:7" Value="0.92" />
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GrainLayer"
                                                                   Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                                   Duration="0:0:0.42"
                                                                   RepeatBehavior="Forever">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.084" Value="-28" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.168" Value="16" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.252" Value="-12" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.336" Value="30" />
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GrainLayer"
                                                                   Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                   Duration="0:0:0.42"
                                                                   RepeatBehavior="Forever">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.084" Value="14" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.168" Value="-32" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.252" Value="-18" />
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.336" Value="22" />
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
