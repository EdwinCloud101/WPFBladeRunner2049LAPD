<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.TooltipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // TOOLTIP"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="TOOLTIP"
                           SectionNumber="17"
                           SectionTitle="TOOLTIP"
                           JpLabel="注釈">
        <WrapPanel>
            <TextBlock Style="{StaticResource Lapd.TipLine}" VerticalAlignment="Bottom" Margin="0,0,6,0"
                       lapd:Tracking.Spaces="1" lapd:Tracking.Text="SUBJECT FLAGGED UNDER" />
            <StackPanel VerticalAlignment="Bottom" Margin="0,0,6,0">
                <StackPanel.ToolTip>
                    <ToolTip Style="{StaticResource Lapd.ToolTip}" Content="PROHIBITION ACT 2036 // SEC. 7" />
                </StackPanel.ToolTip>
                <TextBlock Style="{StaticResource Lapd.TipTerm}"
                           lapd:Tracking.Spaces="1" lapd:Tracking.Text="REPLICANT PROHIBITION" />
                <Line X2="1" Stretch="Fill" Stroke="{StaticResource Lapd.TealDim}" StrokeThickness="1" StrokeDashArray="3 3" />
            </StackPanel>
            <TextBlock Style="{StaticResource Lapd.TipLine}" VerticalAlignment="Bottom" Margin="0,0,6,0"
                       lapd:Tracking.Spaces="1" lapd:Tracking.Text="PENDING" />
            <StackPanel VerticalAlignment="Bottom">
                <StackPanel.ToolTip>
                    <ToolTip Style="{StaticResource Lapd.ToolTip}" Content="BASELINE DEVIATION TEST" />
                </StackPanel.ToolTip>
                <TextBlock Style="{StaticResource Lapd.TipTerm}"
                           lapd:Tracking.Spaces="1" lapd:Tracking.Text="RE-EXAMINATION" />
                <Line X2="1" Stretch="Fill" Stroke="{StaticResource Lapd.TealDim}" StrokeThickness="1" StrokeDashArray="3 3" />
            </StackPanel>
            <TextBlock Style="{StaticResource Lapd.TipLine}" VerticalAlignment="Bottom" Text="." />
        </WrapPanel>
    </controls:ConsoleShell>
</Window>
