<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.ImageUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // IMAGE UPLOAD"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="IMAGE UPLOAD"
                           SectionNumber="10"
                           SectionTitle="IMAGE UPLOAD"
                           JpLabel="転送">
        <Button Style="{StaticResource Lapd.Upload}">
            <StackPanel>
                <Viewbox Width="30" Height="30" HorizontalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path Style="{StaticResource Lapd.UploadIcon}"
                              Data="M12,16 L12,4 M6.5,9.5 L12,4 L17.5,9.5 M4,20 L20,20" />
                    </Canvas>
                </Viewbox>
                <TextBlock Style="{StaticResource Lapd.UploadL1}"
                           lapd:Tracking.Spaces="2"
                           lapd:Tracking.Text="DROP IMAGE FILE" />
                <TextBlock Style="{StaticResource Lapd.UploadL2}"
                           lapd:Tracking.Spaces="1"
                           lapd:Tracking.Text="OR CLICK TO BROWSE // 8 MB MAX" />
            </StackPanel>
        </Button>
    </controls:ConsoleShell>
</Window>
