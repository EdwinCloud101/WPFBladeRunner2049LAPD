<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.SpinnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // SPINNER"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="SPINNER"
                           SectionNumber="15"
                           SectionTitle="SPINNER"
                           JpLabel="処理中">
        <StackPanel Orientation="Horizontal">
            <ContentControl Style="{StaticResource Lapd.Spinner}" Margin="0,0,40,0" />
            <ContentControl Style="{StaticResource Lapd.SpinnerSmooth}" Margin="0,0,40,0" VerticalAlignment="Center" />
            <TextBlock Style="{StaticResource Lapd.SpinnerLabel}" VerticalAlignment="Center"
                       lapd:Tracking.Spaces="2"
                       lapd:Tracking.Text="CROSS-REFERENCING ARCHIVE&#x2026;" />
        </StackPanel>
    </controls:ConsoleShell>
</Window>
