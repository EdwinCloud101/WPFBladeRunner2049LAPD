<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.DataGridWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // DATAGRID"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <Window.Resources>
        <DataTemplate x:Key="HeadTemplate">
            <TextBlock lapd:Tracking.Spaces="2"
                       lapd:Tracking.Text="{Binding}" />
        </DataTemplate>
        <DataTemplate x:Key="IdCell">
            <TextBlock Style="{StaticResource Lapd.GridId}"
                       lapd:Tracking.Spaces="1"
                       lapd:Tracking.Text="{Binding [0]}" />
        </DataTemplate>
        <DataTemplate x:Key="SubjectCell">
            <TextBlock Style="{StaticResource Lapd.GridText}"
                       lapd:Tracking.Spaces="1"
                       lapd:Tracking.Text="{Binding [1]}" />
        </DataTemplate>
        <DataTemplate x:Key="ClassCell">
            <TextBlock Style="{StaticResource Lapd.GridText}"
                       lapd:Tracking.Spaces="1"
                       lapd:Tracking.Text="{Binding [2]}" />
        </DataTemplate>
        <DataTemplate x:Key="MatchCell">
            <TextBlock Style="{StaticResource Lapd.GridX}" Text="{Binding [3]}" />
        </DataTemplate>
    </Window.Resources>
    <controls:ConsoleShell MastheadTitle="DATAGRID"
                           SectionNumber="07"
                           SectionTitle="DATAGRID"
                           JpLabel="記録">
        <ListView Style="{StaticResource Lapd.DataGrid}">
            <ListView.View>
                <GridView AllowsColumnReorder="False"
                          ColumnHeaderContainerStyle="{StaticResource Lapd.GridHeader}">
                    <GridViewColumn Width="84" Header="ID"
                                    HeaderTemplate="{StaticResource HeadTemplate}"
                                    CellTemplate="{StaticResource IdCell}" />
                    <GridViewColumn Width="360" Header="SUBJECT"
                                    HeaderTemplate="{StaticResource HeadTemplate}"
                                    CellTemplate="{StaticResource SubjectCell}" />
                    <GridViewColumn Width="110" Header="CLASS"
                                    HeaderTemplate="{StaticResource HeadTemplate}"
                                    CellTemplate="{StaticResource ClassCell}" />
                    <GridViewColumn Width="70" Header="MATCH"
                                    HeaderTemplate="{StaticResource HeadTemplate}"
                                    CellTemplate="{StaticResource MatchCell}" />
                </GridView>
            </ListView.View>
            <ListViewItem>
                <ListViewItem.Content>
                    <x:Array Type="sys:String">
                        <sys:String>4847</sys:String>
                        <sys:String>UNKNOWN FEMALE</sys:String>
                        <sys:String>NEXUS-8</sys:String>
                        <sys:String>x</sys:String>
                    </x:Array>
                </ListViewItem.Content>
            </ListViewItem>
            <ListViewItem IsSelected="True">
                <ListViewItem.Content>
                    <x:Array Type="sys:String">
                        <sys:String>2181</sys:String>
                        <sys:String>UNKNOWN MALE</sys:String>
                        <sys:String>NEXUS-8</sys:String>
                        <sys:String>x</sys:String>
                    </x:Array>
                </ListViewItem.Content>
            </ListViewItem>
            <ListViewItem>
                <ListViewItem.Content>
                    <x:Array Type="sys:String">
                        <sys:String>6601</sys:String>
                        <sys:String>MORTON, SAPPER</sys:String>
                        <sys:String>NEXUS-8</sys:String>
                        <sys:String>x</sys:String>
                    </x:Array>
                </ListViewItem.Content>
            </ListViewItem>
            <ListViewItem>
                <ListViewItem.Content>
                    <x:Array Type="sys:String">
                        <sys:String>0394</sys:String>
                        <sys:String>RESTRICTED</sys:String>
                        <sys:String>&#x2014;</sys:String>
                        <sys:String>x</sys:String>
                    </x:Array>
                </ListViewItem.Content>
            </ListViewItem>
        </ListView>
    </controls:ConsoleShell>
</Window>
