<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.SliderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // SLIDER"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="SLIDER"
                           SectionNumber="08"
                           SectionTitle="SLIDER"
                           JpLabel="利得">
        <StackPanel>
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="52" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Lapd.SliderName}" VerticalAlignment="Center"
                           lapd:Tracking.Spaces="1" lapd:Tracking.Text="GAIN" />
                <Slider Grid.Column="1" Style="{StaticResource Lapd.Slider}" Margin="14,0" Minimum="0" Maximum="100" Value="62" />
                <TextBlock Grid.Column="2" Style="{StaticResource Lapd.SliderValue}" VerticalAlignment="Center" Text="062" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="52" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Lapd.SliderName}" VerticalAlignment="Center"
                           lapd:Tracking.Spaces="1" lapd:Tracking.Text="EXPOSURE" />
                <Slider Grid.Column="1" Style="{StaticResource Lapd.Slider}" Margin="14,0" Minimum="0" Maximum="100" Value="31" />
                <TextBlock Grid.Column="2" Style="{StaticResource Lapd.SliderValue}" VerticalAlignment="Center" Text="031" />
            </Grid>
        </StackPanel>
    </controls:ConsoleShell>
</Window>
