<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lapd="clr-namespace:BladeRunner2049.Lapd.Styles;assembly=BladeRunner2049.Lapd.Styles"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // COLOR PICKER"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="COLOR PICKER"
                           SectionNumber="19"
                           SectionTitle="COLOR PICKER"
                           JpLabel="色彩">
        <StackPanel Orientation="Horizontal">
            <RadioButton Style="{StaticResource Lapd.Swatch}" GroupName="clr" Background="#FF5FE8D2" IsChecked="True" Margin="0,0,13,0" />
            <RadioButton Style="{StaticResource Lapd.Swatch}" GroupName="clr" Background="#FFAEFCEC" Margin="0,0,13,0" />
            <RadioButton Style="{StaticResource Lapd.Swatch}" GroupName="clr" Background="#FF3C9DD8" Margin="0,0,13,0" />
            <RadioButton Style="{StaticResource Lapd.Swatch}" GroupName="clr" Background="#FFFFB13C" Margin="0,0,13,0" />
            <RadioButton Style="{StaticResource Lapd.Swatch}" GroupName="clr" Background="#FFFF6E3C" />
            <Button Style="{StaticResource Lapd.ColorWell}" Background="#FF5FE8D2" Margin="26,0,10,0" />
            <TextBlock Style="{StaticResource Lapd.StripTag}" VerticalAlignment="Center"
                       lapd:Tracking.Spaces="2" lapd:Tracking.Text="CUSTOM // PHOSPHOR" />
        </StackPanel>
    </controls:ConsoleShell>
</Window>
