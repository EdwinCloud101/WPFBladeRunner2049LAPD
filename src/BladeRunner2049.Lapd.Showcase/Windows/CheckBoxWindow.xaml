<Window x:Class="BladeRunner2049.Lapd.Showcase.Windows.CheckBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BladeRunner2049.Lapd.Showcase.Controls"
        Title="LAPD OS 9.22 // CHECKBOX"
        Width="1100" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Lapd.BgDeep}">
    <controls:ConsoleShell MastheadTitle="CHECKBOX"
                           SectionNumber="03"
                           SectionTitle="CHECKBOX"
                           JpLabel="データ群">
        <StackPanel HorizontalAlignment="Left">
            <CheckBox Style="{StaticResource Lapd.CheckBox}" Content="DATA GROUP" IsChecked="True" Margin="0,0,0,12" />
            <CheckBox Style="{StaticResource Lapd.CheckBox}" Content="DR CLASS" IsChecked="True" Margin="0,0,0,12" />
            <CheckBox Style="{StaticResource Lapd.CheckBox}" Content="ARCHIVE LOCK" />
        </StackPanel>
    </controls:ConsoleShell>
</Window>
